            MDButtonText:
               text: i18n.get_text("save_faceit", app.lang_trigger)

<HelpScreen>:
   name: "help"
   MDBoxLayout:
      orientation: "vertical"
      md_bg_color: 0, 0, 0, 0
      MDTopAppBar:
         type: "small"
         MDTopAppBarLeadingButtonContainer:
            MDActionTopAppBarButton:
               icon: "home"
               on_release: app.switch_screen("home")
         MDTopAppBarTitle:
            # F7-31: current_topic_title property required on HelpScreen. Depends on F7-09 fix.
            text: root.current_topic_title
      MDBoxLayout:
         orientation: "horizontal"
         padding: "12dp"
         spacing: "12dp"
         # Sidebar
         MDBoxLayout:
            orientation: "vertical"
            size_hint_x: 0.3
            spacing: "8dp"
            MDTextField:
               id: search_field
               size_hint_y: None
               height: "48dp"
               on_text: root.filter_topics(self.text)
               MDTextFieldHintText:
                  text: i18n.get_text("search", app.lang_trigger)
            ScrollView:
               MDBoxLayout:
                  id: topic_list
                  orientation: "vertical"
                  adaptive_height: True
                  spacing: "4dp"
         # Content area
         ScrollView:
            size_hint_x: 0.7
            MDLabel:
               id: content_label
               text: ""
               halign: "left"
               valign: "top"
               adaptive_height: True
               padding: ["16dp", "16dp"]
               markup: False

<SettingsScreen>:
   name: "settings"
   MDBoxLayout:
      orientation: "vertical"
      md_bg_color: 0, 0, 0, 0
      MDTopAppBar:
         type: "small"
         MDTopAppBarLeadingButtonContainer:
            MDActionTopAppBarButton:
               icon: "home"
               on_release: app.switch_screen("home")
         MDTopAppBarTitle:
            text: i18n.get_text("settings", app.lang_trigger)
      ScrollView:
         MDBoxLayout:
            orientation: "vertical"
            padding: "20dp"
            spacing: "24dp"
            adaptive_height: True

            # --- Theme Section ---
            SectionHeader:
               icon: "palette"
               title: i18n.get_text("visual_theme", app.lang_trigger)
            MDBoxLayout:
               orientation: "horizontal"
               spacing: "10dp"
               adaptive_height: True
               padding: [0, "4dp", 0, "8dp"]
               MDButton:
                  style: "filled"
                  md_bg_color: 0.85, 0.4, 0, 1
                  on_release: app.set_app_theme("CS2")
                  MDButtonText:
                     text: "CS2"
               MDButton:
                  style: "filled"
                  md_bg_color: 0.3, 0.4, 0.5, 1
                  on_release: app.set_app_theme("CSGO")
                  MDButtonText:
                     text: "CS:GO"
               MDButton:
                  style: "filled"
                  md_bg_color: 0.2, 0.5, 0.2, 1
                  on_release: app.set_app_theme("CS1.6")
                  MDButtonText:
                     text: "CS 1.6"

            MDButton:
               style: "outlined"
               pos_hint: {"center_x": .5}
               on_release: app.cycle_wallpaper()
               MDButtonText:
                  text: i18n.get_text("cycle_wallpaper", app.lang_trigger)

            MDDivider:

            # --- Analysis Configuration ---
            SectionHeader:
               icon: "folder-cog"
               title: i18n.get_text("analysis_paths", app.lang_trigger)

            AppSettingItem:
               title: i18n.get_text("change_default_folder", app.lang_trigger) + ":"
               value: root.current_default_folder
            MDButton:
               style: "outlined"
               on_release: app.open_folder_picker(target="default")
               MDButtonText:
                  text: i18n.get_text("change_default_folder", app.lang_trigger)

            AppSettingItem:
               title: i18n.get_text("change_pro_folder", app.lang_trigger) + ":"
               value: root.current_pro_folder
            MDButton:
               style: "outlined"
               on_release: app.open_folder_picker(target="pro")
               MDButtonText:
                  text: i18n.get_text("change_pro_folder", app.lang_trigger)

            MDDivider:

            # --- Appearance Section ---
            SectionHeader:
               icon: "format-size"
               title: i18n.get_text("appearance", app.lang_trigger)

            MDLabel:
               text: i18n.get_text("font_size", app.lang_trigger) + ": " + root.current_font_size
               font_style: "Body"
               role: "medium"
            MDBoxLayout:
               orientation: "horizontal"
               spacing: "10dp"
               adaptive_height: True
               MDButton:
                  style: "elevated"
                  on_release: app.set_font_size("Small")
                  MDButtonText:
                     text: "Small"
               MDButton:
                  style: "elevated"
                  on_release: app.set_font_size("Medium")
                  MDButtonText:
                     text: "Medium"
               MDButton:
                  style: "elevated"
                  on_release: app.set_font_size("Large")
                  MDButtonText:
                     text: "Large"

            MDDivider:

            # --- Data Ingestion Control ---
            SectionHeader:
               icon: "database-sync"
               title: i18n.get_text("data_ingestion", app.lang_trigger)  # F7-18

            AppSettingItem:
               title: "Ingestion Mode:"
               value: "Auto (Continuous)" if app.ingest_mode_auto else "Manual"

            MDBoxLayout:
               orientation: "horizontal"
               spacing: "20dp"
               adaptive_height: True
               padding: [0, "10dp", 0, "10dp"]

               MDButton:
                  style: "filled" if not app.ingest_mode_auto else "outlined"
                  md_bg_color: (0.15, 0.5, 0.8, 1) if not app.ingest_mode_auto else (0, 0, 0, 0)
                  on_release: app.set_ingest_mode(False)
                  MDButtonText:
                     text: "Manual"

               MDButton:
                  style: "filled" if app.ingest_mode_auto else "outlined"
                  md_bg_color: (0.15, 0.5, 0.8, 1) if app.ingest_mode_auto else (0, 0, 0, 0)
                  on_release: app.set_ingest_mode(True)
                  MDButtonText:
                     text: "Auto"

            AppSettingItem:
               title: "Scan Interval (min):"
               value: str(app.ingest_interval)

            MDBoxLayout:
               orientation: "horizontal"
               spacing: "10dp"
               adaptive_height: True

               MDTextField:
                  id: interval_field
                  text: str(app.ingest_interval)
                  input_filter: "int"
                  size_hint_x: 0.3
                  MDTextFieldHintText:
                     text: "Minutes"

               MDButton:
                  style: "text"
                  on_release: app.update_ingest_interval(interval_field.text)
                  MDButtonText:
                     text: "Set"

            MDBoxLayout:
               orientation: "horizontal"
               spacing: "20dp"
               adaptive_height: True
               padding: [0, "16dp", 0, "8dp"]

               MDButton:
                  style: "filled"
                  md_bg_color: 0.1, 0.6, 0.3, 1
                  on_release: app.start_manual_ingestion()
                  MDButtonText:
                     text: "Start Ingestion Now"

               MDButton:
                  style: "filled"
                  md_bg_color: 0.75, 0.18, 0.18, 1
                  on_release: app.stop_manual_ingestion()
                  MDButtonText:
                     text: "Stop Ingestion"

            MDDivider:

            # --- Font Type Section (moved from Appearance) ---
            MDLabel:
               text: i18n.get_text("font_type", app.lang_trigger) + ": " + root.current_font_type
               font_style: "Body"
               role: "medium"
            MDBoxLayout:
               orientation: "horizontal"
               spacing: "10dp"
               adaptive_height: True
               MDButton:
                  style: "elevated"
                  on_release: app.set_font_type("Roboto")
                  MDButtonText:
                     text: "Roboto"
               MDButton:
                  style: "elevated"
                  on_release: app.set_font_type("Arial")
                  MDButtonText:
                     text: "Arial"
               MDButton:
                  style: "elevated"
                  on_release: app.set_font_type("JetBrains Mono")
                  MDButtonText:
                     text: "JetBrains"
               MDButton:
                  style: "elevated"
                  on_release: app.set_font_type("New Hope")
                  MDButtonText:
                     text: "New Hope"
               MDButton:
                  style: "elevated"
                  on_release: app.set_font_type("CS Regular")
                  MDButtonText:
                     text: "CS Regular"
               MDButton:
                  style: "elevated"
                  on_release: app.set_font_type("YUPIX")
                  MDButtonText:
                     text: "YUPIX"

            MDDivider:

            # --- Language Section ---
            SectionHeader:
               icon: "translate"
               title: i18n.get_text("language", app.lang_trigger)
            MDBoxLayout:
               orientation: "horizontal"
               spacing: "10dp"
               adaptive_height: True
               padding: [0, "4dp", 0, "8dp"]
               MDButton:
                  style: "filled"
                  md_bg_color: 0.15, 0.25, 0.55, 1
                  on_release: app.set_language("en")
                  MDButtonText:
                     text: "English"
               MDButton:
                  style: "filled"
                  md_bg_color: 0.1, 0.45, 0.2, 1
                  on_release: app.set_language("it")
                  MDButtonText:
                     text: "Italiano"
               MDButton:
                  style: "filled"
                  md_bg_color: 0.1, 0.4, 0.15, 1
                  on_release: app.set_language("pt")
                  MDButtonText:
                     text: "Português"

<WizardScreen>:
   name: "wizard"
   MDBoxLayout:
      orientation: "vertical"
      padding: "24dp"
      spacing: "24dp"

      MDLabel:
         id: title_label
         text: i18n.get_text("welcome", app.lang_trigger)
         font_style: "Headline"
         role: "medium"
         halign: "center"
         adaptive_height: True

      MDDivider:

      MDBoxLayout:
         id: content_area
         orientation: "vertical"
         # specific content injected by python

      AnchorLayout:
         anchor_x: "center"
         size_hint_y: None
         height: "60dp"
         MDButton:
            id: next_btn
            style: "elevated"
            md_bg_color: app.theme_cls.primaryColor
            on_release: root.next_action()
            MDButtonText:
               text: i18n.get_text("next", app.lang_trigger)

<TacticalViewerScreen>:
   name: "tactical_viewer"
   MDBoxLayout:
      orientation: "vertical"
      MDTopAppBar:
         type: "small"
         MDTopAppBarLeadingButtonContainer:
            MDActionTopAppBarButton:
               icon: "arrow-left"
               on_release: app.switch_screen("home")
         MDTopAppBarTitle:
            text: i18n.get_text("tactical_analyzer", app.lang_trigger)
         MDTopAppBarTrailingButtonContainer:
            MDActionTopAppBarButton:
               icon: "folder-open"
               on_release: app.trigger_viewer_picker()

      MDBoxLayout:
         orientation: "horizontal"
         PlayerSidebar:
            id: ct_sidebar
            team_name: "COUNTER-TERRORIST"
            team_color: 0.3, 0.5, 1, 1
            size_hint_x: 0.2

         TacticalMap:
            id: tactical_map
            size_hint_x: 0.6

         PlayerSidebar:
            id: t_sidebar
            team_name: "TERRORIST"
            team_color: 1, 0.6, 0.2, 1
            size_hint_x: 0.2

      MDBoxLayout:
         size_hint_y: None
         height: "120dp"
         orientation: "vertical"
         padding: "8dp"
         MDBoxLayout:
            orientation: "horizontal"
            spacing: "10dp"
            adaptive_height: True
            Spinner:
               id: map_spinner
               text: i18n.get_text("select_map", app.lang_trigger)
               size_hint_x: 0.3
               on_text: root.switch_map(self.text)
            Spinner:
               id: round_spinner
               text: i18n.get_text("select_round", app.lang_trigger)
               size_hint_x: 0.3
               on_text: root.on_round_change(self.text)
            MDLabel:
               id: tick_label
               text: "Tick: 0"
               halign: "right"
               size_hint_x: 0.2
            Switch:
               active: False
               on_active: tactical_map.debug_mode = self.active
               size_hint_x: None
               width: "48dp"
            MDLabel:
               text: i18n.get_text("debug", app.lang_trigger)
               font_style: "Body"
               role: "small"
               size_hint_x: None
               width: "40dp"

            Switch:
               id: ghost_switch
               active: root.ghost_active
               on_active: root.ghost_active = self.active
               size_hint_x: None
               width: "48dp"
            MDLabel:
               text: "GHOST"
               font_style: "Body"
               role: "small"
               bold: True
               theme_text_color: "Custom"
               text_color: 0.8, 0.4, 1, 1
               size_hint_x: None
               width: "45dp"

         MDBoxLayout:
            orientation: "horizontal"
            spacing: "16dp"
            padding: [0, "10dp", 0, 0]
            MDIconButton:
               icon: "skip-previous-circle-outline"
               style: "standard"
               on_release: root.jump_to_prev_cm()
            MDIconButton:
               id: play_btn
               icon: "play"
               style: "standard"
               on_release: root.toggle_playback()
            MDIconButton:
               icon: "skip-next-circle-outline"
               style: "standard"
               on_release: root.jump_to_next_cm()
            MDButton:
               style: "elevated"
               on_release: root.set_speed(0.5)
               MDButtonText:
                  text: "0.5x"
            MDButton:
               style: "elevated"
               on_release: root.set_speed(0.75)
               MDButtonText:
                  text: "0.75x"
            MDButton:
               style: "elevated"
               on_release: root.set_speed(1.0)
               MDButtonText:
                  text: "1x"
            MDButton:
               style: "elevated"
               on_release: root.set_speed(2.0)
               MDButtonText:
                  text: "2x"
            MDButton:
               style: "elevated"
               on_release: root.set_speed(4.0)
               MDButtonText:
                  text: "4x"

         TimelineScrubber:
            id: timeline
            size_hint_y: None
            height: "40dp"

<MatchHistoryScreen>:
   name: "match_history"
   MDBoxLayout:
      orientation: "vertical"
      md_bg_color: 0, 0, 0, 0
      MDTopAppBar:
         type: "small"
         MDTopAppBarLeadingButtonContainer:
            MDActionTopAppBarButton:
               icon: "arrow-left"
               on_release: app.switch_screen("home")
         MDTopAppBarTitle:
            text: i18n.get_text("match_history_title", app.lang_trigger)  # F7-18
         MDTopAppBarTrailingButtonContainer:
            MDActionTopAppBarButton:
               icon: "chart-line"
               on_release: app.switch_screen("performance")
      ScrollView:
         MDBoxLayout:
            id: match_list_container
            orientation: "vertical"
            padding: "16dp"
            spacing: "8dp"
            adaptive_height: True

<MatchDetailScreen>:
   name: "match_detail"
   MDBoxLayout:
      orientation: "vertical"
      md_bg_color: 0, 0, 0, 0
      MDTopAppBar:
         type: "small"
         MDTopAppBarLeadingButtonContainer:
            MDActionTopAppBarButton:
               icon: "arrow-left"
               on_release: app.switch_screen("match_history")
         MDTopAppBarTitle:
            text: "Match Detail"
      ScrollView:
         MDBoxLayout:
            id: detail_container
            orientation: "vertical"
            padding: "16dp"
            spacing: "12dp"
            adaptive_height: True

<PerformanceScreen>:
   name: "performance"
   MDBoxLayout:
      orientation: "vertical"
      md_bg_color: 0, 0, 0, 0
      MDTopAppBar:
         type: "small"
         MDTopAppBarLeadingButtonContainer:
            MDActionTopAppBarButton:
               icon: "arrow-left"
               on_release: app.switch_screen("home")
         MDTopAppBarTitle:
            text: "Performance Dashboard"
         MDTopAppBarTrailingButtonContainer:
            MDActionTopAppBarButton:
               icon: "history"
               on_release: app.switch_screen("match_history")
      ScrollView:
         MDBoxLayout:
            id: performance_container
            orientation: "vertical"
            padding: "16dp"
            spacing: "12dp"
            adaptive_height: True
